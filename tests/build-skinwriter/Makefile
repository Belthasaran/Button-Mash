####### Compile

test_skinwriter.o: ../test_skinwriter.cpp ../../../../button-mash/skinparser.h \
		../../skinwriter.h \
		../../skinparser.h \
		../../skinmetadata.h \
		../../skinutil.h \
		../../masheditormodel.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o test_skinwriter.o ../test_skinwriter.cpp

skinparser.o: ../../skinparser.cpp ../../skinparser.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o skinparser.o ../../skinparser.cpp

skinwriter.o: ../../skinwriter.cpp ../../skinwriter.h \
		../../skinparser.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o skinwriter.o ../../skinwriter.cpp

skinmetadata.o: ../../skinmetadata.cpp ../../skinmetadata.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o skinmetadata.o ../../skinmetadata.cpp

skinutil.o: ../../skinutil.cpp ../../skinutil.h \
		../../skinparser.h \
		../../skinwriter.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o skinutil.o ../../skinutil.cpp

masheditormodel.o: ../../masheditormodel.cpp ../../masheditormodel.h \
		../../skinmetadata.h \
		../../skinparser.h \
		../../skinutil.h \
		../../skinwriter.h \
		../../inputprovider.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o masheditormodel.o ../../masheditormodel.cpp

inputprovider.o: ../../inputprovider.cpp ../../inputprovider.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o inputprovider.o ../../inputprovider.cpp

moc_inputprovider.o: moc_inputprovider.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_inputprovider.o moc_inputprovider.cpp

